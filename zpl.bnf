// ZPL grammar as implemented by the compiler in src/ (lex.rs, parser.rs,
// allow.rs, define.rs, never.rs). Originally extracted from ZRFC 15, then
// reconciled against the code.
//
// TERMINOLOGY DRIFT — "device" vs "endpoint":
//   ZRFC 15 uses the term ***device***/***devices*** (with a predefined subclass
//   ***servers***) for the entity that connects to the ZPRnet. The compiler has
//   NOT adopted this rename: it still uses the older term "endpoint"/"endpoints"
//   throughout (TokenType, ClassFlavor::Endpoint, DEF_CLASS_ENDPOINT_NAME, ...).
//   This BNF follows the CODE, so it uses "endpoint" below. Everywhere you see
//   <endpoint-spec>, <endpoint-class-name>, "endpoint", or "endpoints", the ZRFC
//   would say "device"/"devices".
//
// NOT YET IMPLEMENTED (documented in ZRFC 15 but absent from the compiler):
//   - the predefined "servers" class (a subclass of devices with a set-valued
//     "services" attribute)
//   - the predefined "link"/"links" class
//   - the "over ... links" clause on allow/never statements (link constraints),
//     e.g. "... to access customer databases over secure links."
//   - conditions / circumstances / limits (e.g. "before 18:00 GMT", "limited to 10Gb/day")
//
// KEYWORD STATE (from lex.rs):
//   - Active keywords: never, allow, define, with, to, access, and, as, aka,
//     tag, tags, on, optional, multiple, signal (plus "," as AND, "." as terminator).
//   - "a"/"an" are dropped as syntactic sugar wherever they appear (not just after "as").
//   - "without" and "from" ARE tokenized as reserved keywords but are not
//     accepted by any grammar rule; using them is a syntax error. (Neither appears
//     in ZRFC 15; they are compiler-reserved for anticipated future clauses.)
//   - "link", "links", "over" are NOT tokenized; if written they parse as ordinary
//     literals. ZRFC 15 uses them for the link class and "over" clause (see above),
//     so they are effectively spec keywords the compiler has not yet reserved.

<zpl-policy> ::= <statement>*

// Statements are delimited by a terminating period OR by the start of the next
// allow/define/never keyword. A trailing period is therefore optional in practice.
<statement> ::= <permission-statement> | <denial-statement> | <define-statement>

<permission-statement> ::= "allow" <p-statement>

<denial-statement> ::= "never" "allow" <p-statement>

<define-statement> ::= "define" <name> <aka-clause>? "as" <class-name>
                       <with-attributes-clause>? "."?

<p-statement> ::= <subject-clause> "to" "access" <object-clause> <signal-clause>? "."?

<subject-clause> ::= <user-spec> | <service-spec> | <endpoint-spec> |
                     <user-spec> "on" <endpoint-spec> |
                     <service-spec> "on" <endpoint-spec>

<object-clause> ::= <service-spec> | <service-spec> "on" <endpoint-spec>

// The "and"/"," before "signal" are optional delimiters (consumed but not required).
<signal-clause> ::= ","? "and"? "signal" <string> "to" <service-class-name>

<aka-clause> ::= "aka" <name>

// --- Class definition attribute list (define.rs::parse_attributes) ---
//
// A "with" clause is a sequence of attribute specs separated by "and"/",".
// An additional group can be started with the two-token sequence "and" "with".
<with-attributes-clause> ::= "with" <attribute-list> ("and" "with" <attribute-list>)*

<attribute-list> ::= <attribute-spec> (<and-token> <attribute-spec>)*

<and-token> ::= "and" | ","

// "multiple" forces a multi-valued attribute (also implied by set-valued literal).
// "optional" applies only to tags. "tag" takes a single following name (non-greedy);
// "tags" is greedy and consumes all following names until the next "and with".
<attribute-spec> ::= "multiple"? (<attr-kv-pair> | <attr-key-presence> | <name>) |
                     "optional"? ("tag" | "tags") <name> (<and-token> <name>)*

// --- Clause specs used in allow/never statements ---
//
// A spec is a class name together with zero or more attribute expressions.
// The class name may appear before OR after the attribute expressions, and at
// most one class name may appear per spec. The postfix "with ..." form is a
// hard error (kept only to emit a helpful migration message).

<user-spec> ::= (<attribute-expr> | <user-class-name>)+
// A <user-class-name> must be, or descend from, the built-in "user" class.
<user-class-name> ::= <name> | <built-in-user-class-name>

<endpoint-spec> ::= (<attribute-expr> | <endpoint-class-name>)+
// An <endpoint-class-name> must be, or descend from, the built-in "endpoint" class.
<endpoint-class-name> ::= <name> | <built-in-endpoint-class-name>

<service-spec> ::= (<attribute-expr> | <service-class-name>)+
// A <service-class-name> must be, or descend from, the built-in "service" class.
<service-class-name> ::= <name> | <built-in-service-class-name>

<attribute-expr> ::= <attr-tag> | <attr-kv-pair> | <attr-key-presence>

<attr-tag> ::= <name>

// No spaces around ':' in <attr-kv-pair>
<attr-kv-pair> ::= <key-name> ":" <key-value>

// No space may precede the ':' in <attr-key-presence>
<attr-key-presence> ::= <key-name> ":"

<key-name> ::= <name>

<key-value> ::= <value>

<name> ::= <identifier> | <string> | <namespace-name>

<namespace-name> ::= <name> "." <name>

<class-name> ::= <built-in-class-name> | <name>

<built-in-class-name> ::= <built-in-endpoint-class-name> |
                          <built-in-service-class-name> |
                          <built-in-user-class-name>

// ZRFC 15 calls this class "device"/"devices" (with subclass "server"/"servers");
// the compiler has not yet adopted that rename and only accepts "endpoint"/"endpoints".
<built-in-endpoint-class-name> ::= "endpoint" | "endpoints"

// "VisaService"/"VisaServices" is a predefined service class (Class::defaults()),
// but it is NOT extensible: it may not be used as a parent in a define statement.
<built-in-service-class-name> ::= "service" | "services" | "VisaService" | "VisaServices"

<built-in-user-class-name> ::= "user" | "users"

<identifier> ::= <letter> (<letter> | <digit> | "-" | "_")*

<value> ::= <string> | <value-set>

<string> ::= <quoted-string> | <numeric-string>

<quoted-string> ::= <single-quoted-string> | <double-quoted-string>

<single-quoted-string> ::= <single-quote> <single-quote-chars> <single-quote>

<double-quoted-string> ::= '"' <double-quote-chars> '"'

<single-quote-chars> ::= (<any-char-except-single-quote-or-backslash> | <escaped-char>)*

<double-quote-chars> ::= (<any-char-except-double-quote-or-backslash> | <escaped-char>)*

<escaped-char> ::= "\'" | '\"' | "\\"

<numeric-string> ::= <integer> | <float>

<integer> ::= <digit>+

<float> ::= <digit>+ "." <digit>+

<value-set> ::= "{" <value> ("," <value>)* "}"

<single-quote> ::= "'" | "`"

<letter> ::= "a".."z" | "A".."Z"

<digit> ::= "0".."9"

<comment> ::= "#" <any-chars-to-eol> | "//" <any-chars-to-eol>
